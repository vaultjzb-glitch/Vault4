<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#080910">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="VAULT">
<link rel="manifest" href="manifest.json">
<title>VAULT — Private AI</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Courier+Prime:wght@400;700&family=Sora:wght@300;400;500&display=swap');
:root{--bg:#080910;--s1:#0e0f16;--s2:#14151f;--s3:#1a1b28;--b1:#252636;--b2:#2f3048;--cyan:#00e5ff;--purple:#7b61ff;--green:#00ff88;--red:#ff4466;--amber:#ffaa00;--text:#dde1f0;--muted:#4a4d6b;--muted2:#6b6f8e;--mono:'Courier Prime',monospace;--head:'Rajdhani',sans-serif;--body:'Sora',sans-serif;--safe-bottom:env(safe-area-inset-bottom,0px);--safe-top:env(safe-area-inset-top,0px);}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{height:100%;}
body{background:var(--bg);color:var(--text);font-family:var(--body);height:100%;display:flex;flex-direction:column;overflow:hidden;padding-top:var(--safe-top);padding-bottom:var(--safe-bottom);}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,229,255,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,255,0.018) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;}
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.025) 3px,rgba(0,0,0,0.025) 4px);pointer-events:none;z-index:1000;}

/* ═══ API MODAL ═══ */
#apiModal{position:fixed;inset:0;background:rgba(8,9,16,0.97);z-index:950;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;}
#apiModal.hidden{display:none;}
.api-logo{font-family:var(--head);font-size:48px;font-weight:700;letter-spacing:.18em;color:var(--cyan);text-shadow:0 0 40px rgba(0,229,255,0.5);margin-bottom:6px;}
.api-subtitle{font-family:var(--mono);font-size:9px;color:var(--muted2);letter-spacing:.25em;text-transform:uppercase;margin-bottom:40px;}
.api-box{width:100%;max-width:400px;background:var(--s2);border:1px solid var(--b2);padding:24px;position:relative;}
.api-box::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--purple),var(--cyan));}
.api-label{font-family:var(--mono);font-size:9px;color:var(--muted2);letter-spacing:.15em;margin-bottom:10px;}
.api-input-wrap{display:flex;border:1px solid var(--b2);background:var(--s3);overflow:hidden;margin-bottom:14px;transition:border-color .2s,box-shadow .2s;}
.api-input-wrap:focus-within{border-color:rgba(0,229,255,.4);box-shadow:0 0 0 1px rgba(0,229,255,.08);}
.api-prefix{padding:0 10px;display:grid;place-items:center;font-family:var(--mono);font-size:9px;color:var(--purple);background:rgba(123,97,255,.08);border-right:1px solid var(--b2);flex-shrink:0;user-select:none;}
#apiKeyInput{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:var(--mono);font-size:12px;padding:12px;letter-spacing:.05em;}
#apiKeyInput::placeholder{color:var(--muted);}
.api-toggle{padding:0 12px;background:transparent;border:none;border-left:1px solid var(--b2);cursor:pointer;color:var(--muted2);font-size:14px;transition:color .2s;}
.api-submit{width:100%;padding:13px;font-family:var(--head);font-size:14px;font-weight:600;letter-spacing:.15em;background:transparent;border:1px solid rgba(0,229,255,.5);color:var(--cyan);cursor:pointer;transition:all .2s;}
.api-submit:hover{background:rgba(0,229,255,.08);box-shadow:0 0 20px rgba(0,229,255,.15);}
.api-warn{font-family:var(--mono);font-size:9px;color:var(--amber);letter-spacing:.06em;margin-top:14px;text-align:center;}
.api-err{font-family:var(--mono);font-size:9px;color:var(--red);letter-spacing:.06em;margin-top:10px;text-align:center;display:none;}

/* ═══ BOOT ═══ */
#boot{position:fixed;inset:0;background:var(--bg);z-index:900;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 32px;transition:opacity 0.6s ease,transform 0.6s ease;}
#boot.out{opacity:0;transform:scale(1.03);pointer-events:none;}
.boot-logo{font-family:var(--head);font-size:clamp(64px,18vw,108px);font-weight:700;letter-spacing:0.18em;color:var(--cyan);text-shadow:0 0 50px rgba(0,229,255,0.6),0 0 100px rgba(0,229,255,0.2);line-height:1;animation:logoFlicker 5s infinite;}
@keyframes logoFlicker{0%,94%,100%{opacity:1;}95%{opacity:.8;}96%{opacity:1;}98%{opacity:.85;}}
.boot-tagline{font-family:var(--mono);font-size:10px;color:var(--muted2);letter-spacing:0.3em;margin-top:6px;margin-bottom:48px;text-transform:uppercase;}
.boot-log{width:100%;max-width:400px;font-family:var(--mono);font-size:11px;display:flex;flex-direction:column;gap:7px;margin-bottom:28px;}
.bl{display:flex;gap:10px;align-items:center;opacity:0;transform:translateX(-8px);animation:blIn 0.25s forwards;}
@keyframes blIn{to{opacity:1;transform:none;}}
.bl-p{color:var(--muted);flex-shrink:0;}.bl-t{flex:1;color:var(--muted2);}.bl-s{margin-left:auto;font-weight:700;letter-spacing:.1em;flex-shrink:0;}
.bl.ok .bl-s{color:var(--green);}.bl.warn .bl-s{color:var(--amber);}.bl.block .bl-s{color:var(--red);}
.boot-prog{width:100%;max-width:400px;height:2px;background:var(--s2);overflow:hidden;margin-bottom:24px;}
.boot-prog-fill{height:100%;background:linear-gradient(90deg,var(--purple),var(--cyan));box-shadow:0 0 12px var(--cyan);width:0;transition:width 2.2s cubic-bezier(.4,0,.2,1);}
.boot-enter{font-family:var(--mono);font-size:11px;color:var(--cyan);letter-spacing:0.2em;padding:12px 28px;border:1px solid rgba(0,229,255,0.5);cursor:pointer;opacity:0;transition:opacity 0.4s,box-shadow 0.3s,background 0.2s;background:transparent;animation:borderPulse 2s infinite;}
.boot-enter.show{opacity:1;}
.boot-enter:hover{background:rgba(0,229,255,0.08);box-shadow:0 0 20px rgba(0,229,255,0.2);}
@keyframes borderPulse{0%,100%{box-shadow:0 0 0 0 rgba(0,229,255,0.3);}50%{box-shadow:0 0 0 8px rgba(0,229,255,0);}}

/* ═══ TOPBAR ═══ */
.topbar{background:var(--s1);border-bottom:1px solid var(--b1);height:52px;display:flex;align-items:center;padding:0 14px;gap:10px;flex-shrink:0;z-index:10;position:relative;}
.tb-logo{font-family:var(--head);font-size:20px;font-weight:700;letter-spacing:.15em;color:var(--cyan);text-shadow:0 0 16px rgba(0,229,255,0.4);}
.tb-session{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.06em;}
.tb-right{margin-left:auto;display:flex;gap:6px;align-items:center;}
.loc-badge{display:flex;align-items:center;gap:5px;font-family:var(--mono);font-size:9px;letter-spacing:.06em;padding:4px 8px;border:1px solid;cursor:pointer;transition:all 0.2s;user-select:none;}
.loc-badge.masked{border-color:rgba(0,255,136,0.4);color:var(--green);background:rgba(0,255,136,0.06);}
.loc-badge.live{border-color:rgba(255,68,102,0.4);color:var(--red);background:rgba(255,68,102,0.06);}
.loc-badge.off{border-color:rgba(74,77,107,0.5);color:var(--muted2);background:transparent;}
.loc-dot{width:5px;height:5px;border-radius:50%;background:currentColor;animation:lp 2s infinite;}
@keyframes lp{0%,100%{opacity:1;}50%{opacity:.3;}}
.vpn-badge{display:flex;align-items:center;gap:4px;font-family:var(--mono);font-size:9px;letter-spacing:.06em;padding:4px 7px;border:1px solid;cursor:pointer;}
.vpn-badge.on{border-color:rgba(0,255,136,0.4);color:var(--green);background:rgba(0,255,136,0.06);}
.vpn-badge.off{border-color:rgba(255,68,102,0.4);color:var(--red);background:rgba(255,68,102,0.06);}

/* ═══ TABS ═══ */
.tabs{display:flex;background:var(--s1);border-bottom:1px solid var(--b1);flex-shrink:0;z-index:9;overflow-x:auto;scrollbar-width:none;}
.tabs::-webkit-scrollbar{display:none;}
.tab{flex:1;min-width:52px;padding:8px 4px;font-family:var(--mono);font-size:8px;letter-spacing:.06em;color:var(--muted2);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:3px;border-bottom:2px solid transparent;transition:all 0.15s;user-select:none;white-space:nowrap;}
.tab:hover{color:var(--text);}
.tab.active{color:var(--cyan);border-bottom-color:var(--cyan);}
.tab-icon{font-size:15px;line-height:1;}

/* ═══ PANELS ═══ */
.panel{display:none;flex:1;overflow:hidden;flex-direction:column;}
.panel.active{display:flex;}

/* ═══ CHAT ═══ */
.messages{flex:1;overflow-y:auto;padding:16px 14px;display:flex;flex-direction:column;gap:16px;scroll-behavior:smooth;}
.messages::-webkit-scrollbar{width:2px;}
.messages::-webkit-scrollbar-thumb{background:var(--b2);}
.sys-msg{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.08em;}
.sys-msg::before,.sys-msg::after{content:'';flex:1;height:1px;background:var(--b1);}
.msg{display:flex;gap:10px;animation:msgIn .3s cubic-bezier(.34,1.56,.64,1);}
.msg.user{flex-direction:row-reverse;}
@keyframes msgIn{from{opacity:0;transform:translateY(10px) scale(.97);}to{opacity:1;transform:none;}}
.av{width:32px;height:32px;flex-shrink:0;display:grid;place-items:center;font-family:var(--head);font-size:12px;font-weight:700;letter-spacing:.04em;position:relative;}
.av.ai{background:var(--s2);border:1px solid var(--b2);color:var(--cyan);}
.av.ai::after{content:'';position:absolute;inset:-3px;border:1px solid rgba(0,229,255,0.12);clip-path:polygon(0 0,60% 0,100% 40%,100% 100%,40% 100%,0 60%);animation:spin 10s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.av.user{background:linear-gradient(135deg,var(--purple),var(--cyan));color:#fff;font-size:11px;}
.mb{flex:1;min-width:0;}
.msg.user .mb{display:flex;flex-direction:column;align-items:flex-end;}
.bub{padding:11px 14px;font-size:13.5px;line-height:1.7;font-weight:300;max-width:88%;word-break:break-word;position:relative;}
.msg.ai .bub{background:var(--s2);border:1px solid var(--b2);border-radius:0 8px 8px 8px;color:var(--text);}
.msg.ai .bub::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--cyan),transparent);opacity:.35;}
.msg.user .bub{background:linear-gradient(135deg,rgba(123,97,255,.13),rgba(0,229,255,.07));border:1px solid rgba(123,97,255,.22);border-radius:8px 0 8px 8px;}
.msg-foot{display:flex;align-items:center;gap:6px;margin-top:4px;font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.05em;}
.msg.user .msg-foot{justify-content:flex-end;}
.enc{color:var(--green);opacity:.7;}
.think-bub{background:var(--s2);border:1px solid var(--b2);padding:13px 16px;display:flex;align-items:center;gap:5px;border-radius:0 8px 8px 8px;position:relative;}
.think-bub::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--cyan),transparent);opacity:.35;}
.td{width:5px;height:5px;border-radius:50%;background:var(--cyan);animation:td 1.2s infinite;}
.td:nth-child(2){animation-delay:.15s;background:var(--purple);}
.td:nth-child(3){animation-delay:.3s;}
@keyframes td{0%,80%,100%{transform:scale(.7);opacity:.3;}40%{transform:scale(1);opacity:1;}}
.cursor{display:inline-block;width:2px;height:13px;background:var(--cyan);margin-left:2px;vertical-align:middle;animation:cur .7s infinite;}
@keyframes cur{0%,50%{opacity:1;}51%,100%{opacity:0;}}
.qcmds{display:flex;gap:5px;overflow-x:auto;padding:8px 14px 4px;scrollbar-width:none;flex-shrink:0;}
.qcmds::-webkit-scrollbar{display:none;}
.qc{padding:4px 9px;background:var(--s2);border:1px solid var(--b1);font-family:var(--mono);font-size:9px;color:var(--muted2);cursor:pointer;white-space:nowrap;flex-shrink:0;transition:all .15s;letter-spacing:.04em;}
.qc:hover{border-color:var(--cyan);color:var(--cyan);background:rgba(0,229,255,.05);}
.input-area{background:var(--s1);border-top:1px solid var(--b1);padding:10px 14px 14px;flex-shrink:0;z-index:10;position:relative;}
.input-wrap{display:flex;border:1px solid var(--b2);background:var(--s2);overflow:hidden;transition:border-color .2s,box-shadow .2s;position:relative;}
.input-wrap::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--purple),var(--cyan));opacity:0;transition:opacity .2s;}
.input-wrap:focus-within{border-color:rgba(0,229,255,.35);box-shadow:0 0 0 1px rgba(0,229,255,.08);}
.input-wrap:focus-within::before{opacity:.6;}
.input-tag{padding:0 10px;display:grid;place-items:center;font-family:var(--mono);font-size:9px;color:var(--purple);background:rgba(123,97,255,.08);border-right:1px solid var(--b2);flex-shrink:0;user-select:none;}
textarea{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:var(--body);font-size:13.5px;font-weight:300;padding:12px;resize:none;min-height:46px;max-height:130px;line-height:1.5;}
textarea::placeholder{color:var(--muted);}
.send-btn{padding:0 14px;background:transparent;border:none;border-left:1px solid var(--b2);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s;flex-shrink:0;}
.send-btn:hover{background:rgba(0,229,255,.08);}
.send-btn:disabled{opacity:.3;cursor:not-allowed;}
.si{width:18px;height:18px;fill:none;stroke:var(--cyan);stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;transition:transform .15s;}
.send-btn:hover .si{transform:translate(1px,-1px);}
.input-foot{display:flex;align-items:center;gap:10px;margin-top:7px;font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:.05em;}
.if-dot{width:4px;height:4px;border-radius:50%;background:var(--green);}

/* ═══ SHARED PANEL COMPONENTS ═══ */
.scroll-panel{flex:1;overflow-y:auto;padding:16px 14px;display:flex;flex-direction:column;gap:12px;}
.scroll-panel::-webkit-scrollbar{width:2px;}
.card{background:var(--s2);border:1px solid var(--b2);padding:16px;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--cyan),transparent);opacity:.2;}
.card.red::before{background:linear-gradient(90deg,var(--red),transparent);opacity:.5;}
.card.green::before{background:linear-gradient(90deg,var(--green),transparent);opacity:.3;}
.card.amber::before{background:linear-gradient(90deg,var(--amber),transparent);opacity:.3;}
.card-title{font-family:var(--head);font-size:14px;font-weight:600;letter-spacing:.08em;color:var(--text);display:flex;align-items:center;gap:8px;margin-bottom:10px;}
.card-title .badge{font-family:var(--mono);font-size:9px;color:var(--muted2);font-weight:400;letter-spacing:.08em;margin-left:auto;}
.tog{width:44px;height:24px;background:var(--s3);border:1px solid var(--b2);border-radius:12px;cursor:pointer;position:relative;transition:all .25s;flex-shrink:0;}
.tog.on{background:rgba(0,255,136,.15);border-color:rgba(0,255,136,.4);}
.tog-knob{position:absolute;top:2px;left:2px;width:18px;height:18px;background:var(--muted2);border-radius:50%;transition:all .25s;}
.tog.on .tog-knob{transform:translateX(20px);background:var(--green);}
.toggle-row{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:6px 0;}
.toggle-label{font-size:12.5px;font-weight:300;color:var(--text);}
.toggle-sub{font-family:var(--mono);font-size:9px;color:var(--muted2);margin-top:1px;letter-spacing:.04em;}
.action-btn{width:100%;padding:14px;font-family:var(--head);font-size:15px;font-weight:600;letter-spacing:.12em;cursor:pointer;border:1px solid;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;background:transparent;}
.action-btn.kill{border-color:var(--red);color:var(--red);}
.action-btn.kill:hover{background:rgba(255,68,102,.1);box-shadow:0 0 20px rgba(255,68,102,.15);}
.action-btn.go{border-color:var(--green);color:var(--green);}
.action-btn.go:hover{background:rgba(0,255,136,.08);}
.action-btn.cyan{border-color:var(--cyan);color:var(--cyan);}
.action-btn.cyan:hover{background:rgba(0,229,255,.08);}
.mini-log{background:var(--s3);border:1px solid var(--b1);padding:10px;font-family:var(--mono);font-size:10px;max-height:150px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;}
.mini-log::-webkit-scrollbar{width:2px;}
.log-line{display:flex;gap:8px;align-items:flex-start;}
.log-time{color:var(--muted);flex-shrink:0;font-size:9px;}
.log-text{color:var(--muted2);flex:1;letter-spacing:.02em;}
.log-text.ok{color:var(--green);}
.log-text.warn{color:var(--amber);}
.log-text.block{color:var(--red);}

/* ═══ LOCATION PANEL ═══ */
.loc-hero{padding:20px;display:flex;flex-direction:column;align-items:center;gap:10px;}
.loc-ring{width:90px;height:90px;position:relative;display:grid;place-items:center;}
.loc-ring-outer{position:absolute;inset:0;border-radius:50%;border:2px solid rgba(0,229,255,.2);animation:ripple 2s infinite;}
.loc-ring-mid{position:absolute;inset:12px;border-radius:50%;border:1px solid rgba(0,229,255,.15);animation:ripple 2s infinite .3s;}
@keyframes ripple{0%,100%{transform:scale(1);opacity:.5;}50%{transform:scale(1.05);opacity:1;}}
.loc-icon-wrap{width:48px;height:48px;border-radius:50%;display:grid;place-items:center;font-size:22px;border:2px solid;transition:all .4s;position:relative;z-index:1;}
.loc-icon-wrap.masked{border-color:var(--green);background:rgba(0,255,136,.08);box-shadow:0 0 20px rgba(0,255,136,.2);}
.loc-icon-wrap.live{border-color:var(--red);background:rgba(255,68,102,.08);box-shadow:0 0 20px rgba(255,68,102,.2);}
.loc-icon-wrap.off{border-color:var(--muted);background:rgba(74,77,107,.1);}
.loc-status-text{font-family:var(--head);font-size:18px;font-weight:600;letter-spacing:.1em;}
.loc-status-text.masked{color:var(--green);}
.loc-status-text.live{color:var(--red);}
.loc-status-text.off{color:var(--muted2);}
.loc-sub{font-family:var(--mono);font-size:10px;color:var(--muted2);letter-spacing:.06em;text-align:center;}
.coords-box{background:var(--s3);border:1px solid var(--b1);padding:12px;font-family:var(--mono);display:flex;flex-direction:column;gap:5px;}
.coord-row{display:flex;justify-content:space-between;align-items:center;}
.coord-label{font-size:9px;color:var(--muted);letter-spacing:.1em;}
.coord-val{font-size:12px;color:var(--cyan);letter-spacing:.04em;}
.coord-val.spoofed{color:var(--green);}
.coord-val.hidden{color:var(--muted);letter-spacing:.15em;}
.mode-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;}
.mode-btn{padding:10px 6px;background:var(--s3);border:1px solid var(--b1);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:5px;transition:all .2s;}
.mode-icon{font-size:18px;}
.mode-label{font-family:var(--mono);font-size:8px;letter-spacing:.08em;color:var(--muted2);}
.mode-btn.active.green{border-color:var(--green);background:rgba(0,255,136,.06);}
.mode-btn.active.red{border-color:var(--red);background:rgba(255,68,102,.06);}
.mode-btn.active.grey{border-color:var(--muted2);background:rgba(74,77,107,.1);}
.mode-btn.active.green .mode-label{color:var(--green);}
.mode-btn.active.red .mode-label{color:var(--red);}
.mode-btn.active.grey .mode-label{color:var(--muted2);}
.spoof-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;}
.spoof-loc{padding:8px 10px;background:var(--s3);border:1px solid var(--b1);cursor:pointer;transition:all .2s;display:flex;flex-direction:column;gap:2px;}
.spoof-loc.selected{border-color:var(--green);background:rgba(0,255,136,.05);}
.sl-city{font-size:12px;font-weight:400;color:var(--text);}
.sl-coords{font-family:var(--mono);font-size:9px;color:var(--muted2);letter-spacing:.04em;}

/* ═══ WATCHDOG PANEL ═══ */
.wd-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}
.wstat{background:var(--s3);border:1px solid var(--b1);padding:10px;text-align:center;}
.wstat-num{font-family:var(--head);font-size:24px;font-weight:700;color:var(--cyan);}
.wstat-num.red{color:var(--red);}
.wstat-num.amber{color:var(--amber);}
.wstat-label{font-family:var(--mono);font-size:8px;color:var(--muted2);letter-spacing:.08em;margin-top:2px;}
.perm-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--s3);}
.perm-item:last-child{border-bottom:none;}
.perm-icon{font-size:18px;flex-shrink:0;width:28px;text-align:center;}
.perm-info{flex:1;}
.perm-name{font-size:13px;font-weight:400;color:var(--text);}
.perm-state{font-family:var(--mono);font-size:9px;color:var(--muted2);letter-spacing:.04em;margin-top:1px;}
.perm-badge{font-family:var(--mono);font-size:8px;padding:3px 7px;border:1px solid;flex-shrink:0;}
.perm-badge.granted{border-color:rgba(255,68,102,.4);color:var(--red);}
.perm-badge.denied{border-color:rgba(0,255,136,.3);color:var(--green);}
.perm-badge.prompt{border-color:rgba(255,170,0,.3);color:var(--amber);}
.perm-badge.unknown{border-color:rgba(74,77,107,.4);color:var(--muted2);}
.watch-pulse{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:wp 1.5s infinite;flex-shrink:0;}
.watch-pulse.alert{background:var(--red);box-shadow:0 0 8px var(--red);}
@keyframes wp{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(1.3);}}

/* ═══ THREATS PANEL ═══ */
.cve-card{background:var(--s2);border:1px solid var(--b2);padding:13px;position:relative;overflow:hidden;margin-bottom:8px;cursor:pointer;transition:border-color .2s;}
.cve-card:hover{border-color:rgba(0,229,255,.3);}
.cve-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;}
.cve-card.critical::before{background:linear-gradient(90deg,var(--red),transparent);opacity:.8;}
.cve-card.high::before{background:linear-gradient(90deg,var(--amber),transparent);opacity:.6;}
.cve-card.medium::before{background:linear-gradient(90deg,var(--cyan),transparent);opacity:.4;}
.cve-header{display:flex;align-items:center;gap:8px;margin-bottom:5px;}
.cve-id{font-family:var(--mono);font-size:11px;font-weight:700;color:var(--cyan);letter-spacing:.05em;}
.cve-sev{font-family:var(--mono);font-size:8px;padding:2px 6px;border:1px solid;flex-shrink:0;}
.cve-sev.critical{border-color:rgba(255,68,102,.6);color:var(--red);background:rgba(255,68,102,.1);}
.cve-sev.high{border-color:rgba(255,170,0,.5);color:var(--amber);background:rgba(255,170,0,.08);}
.cve-sev.medium{border-color:rgba(0,229,255,.4);color:var(--cyan);background:rgba(0,229,255,.06);}
.cve-desc{font-size:12px;color:var(--muted2);line-height:1.5;font-weight:300;}
.cve-footer{display:flex;align-items:center;gap:6px;margin-top:6px;font-family:var(--mono);font-size:9px;color:var(--muted);}

/* ═══ DARK WEB PANEL ═══ */
.breach-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--s3);}
.breach-item:last-child{border-bottom:none;}
.breach-icon{font-size:18px;flex-shrink:0;}
.breach-info{flex:1;}
.breach-name{font-size:13px;font-weight:400;color:var(--text);}
.breach-date{font-family:var(--mono);font-size:9px;color:var(--muted2);margin-top:1px;}
.breach-count{font-family:var(--mono);font-size:9px;padding:2px 7px;border:1px solid rgba(255,68,102,.3);color:var(--red);flex-shrink:0;}
.scan-input-wrap{display:flex;gap:8px;margin-bottom:12px;}
.scan-input{flex:1;background:var(--s3);border:1px solid var(--b2);outline:none;color:var(--text);font-family:var(--mono);font-size:12px;padding:10px 12px;letter-spacing:.04em;}
.scan-input::placeholder{color:var(--muted);}
.scan-btn{padding:10px 14px;background:transparent;border:1px solid rgba(0,229,255,.4);color:var(--cyan);font-family:var(--mono);font-size:10px;letter-spacing:.08em;cursor:pointer;transition:all .2s;white-space:nowrap;}
.scan-btn:hover{background:rgba(0,229,255,.08);}
.scan-btn:disabled{opacity:.4;cursor:not-allowed;}

/* ═══ NETWORK PANEL ═══ */
.net-stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.net-stat{background:var(--s3);border:1px solid var(--b1);padding:12px;}
.net-stat-label{font-family:var(--mono);font-size:9px;color:var(--muted2);letter-spacing:.1em;margin-bottom:4px;}
.net-stat-val{font-family:var(--mono);font-size:13px;color:var(--cyan);letter-spacing:.04em;}
.net-stat-val.red{color:var(--red);}
.net-stat-val.green{color:var(--green);}
.net-stat-val.amber{color:var(--amber);}

/* ═══ NOTES PANEL ═══ */
.note-item{background:var(--s2);border:1px solid var(--b2);padding:12px;position:relative;cursor:pointer;transition:border-color .2s;}
.note-item:hover{border-color:rgba(0,229,255,.3);}
.note-title{font-size:13px;font-weight:400;color:var(--text);margin-bottom:4px;}
.note-preview{font-family:var(--mono);font-size:10px;color:var(--muted2);letter-spacing:.03em;line-height:1.4;}
.note-footer{display:flex;align-items:center;gap:6px;margin-top:8px;font-family:var(--mono);font-size:9px;color:var(--muted);}
.note-del{margin-left:auto;color:var(--red);opacity:.5;cursor:pointer;font-size:14px;padding:2px 4px;}
.note-del:hover{opacity:1;}
.note-editor{display:flex;flex-direction:column;gap:8px;}
.note-title-input{background:var(--s3);border:1px solid var(--b2);outline:none;color:var(--text);font-family:var(--body);font-size:14px;padding:10px 12px;}
.note-title-input::placeholder{color:var(--muted);}
.note-body-input{background:var(--s3);border:1px solid var(--b2);outline:none;color:var(--text);font-family:var(--mono);font-size:12px;padding:10px 12px;resize:none;min-height:120px;line-height:1.6;}
.note-body-input::placeholder{color:var(--muted);}
.note-actions{display:flex;gap:8px;}
.note-save{flex:1;padding:10px;background:transparent;border:1px solid rgba(0,255,136,.4);color:var(--green);font-family:var(--mono);font-size:10px;letter-spacing:.1em;cursor:pointer;transition:all .2s;}
.note-cancel{padding:10px 14px;background:transparent;border:1px solid rgba(74,77,107,.4);color:var(--muted2);font-family:var(--mono);font-size:10px;letter-spacing:.1em;cursor:pointer;}

/* ═══ PRIVACY PANEL ═══ */
.score-card{background:var(--s2);border:1px solid var(--b2);padding:18px;display:flex;align-items:center;gap:18px;position:relative;overflow:hidden;}
.score-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--cyan),transparent);}
.score-ring{position:relative;width:72px;height:72px;flex-shrink:0;}
.score-ring svg{transform:rotate(-90deg);}
.score-ring-track{fill:none;stroke:var(--s3);stroke-width:5;}
.score-ring-fill{fill:none;stroke-width:5;stroke-linecap:round;stroke-dasharray:188.5;transition:stroke-dashoffset 1s ease;}
.score-num{position:absolute;inset:0;display:grid;place-items:center;font-family:var(--head);font-size:22px;font-weight:700;}
.score-info{flex:1;}
.score-title{font-family:var(--head);font-size:16px;font-weight:600;letter-spacing:.08em;margin-bottom:4px;}
.score-sub{font-family:var(--mono);font-size:10px;color:var(--muted2);letter-spacing:.05em;line-height:1.5;}
.priv-check{display:flex;align-items:center;gap:12px;background:var(--s2);border:1px solid var(--b2);padding:12px 14px;}
.pc-icon{width:28px;height:28px;display:grid;place-items:center;border-radius:50%;border:1px solid;font-size:13px;flex-shrink:0;}
.pc-icon.pass{border-color:rgba(0,255,136,.3);background:rgba(0,255,136,.06);}
.pc-icon.fail{border-color:rgba(255,68,102,.3);background:rgba(255,68,102,.06);}
.pc-icon.warn{border-color:rgba(255,170,0,.3);background:rgba(255,170,0,.06);}
.pc-text{flex:1;}
.pc-title{font-size:13px;font-weight:400;color:var(--text);}
.pc-sub{font-family:var(--mono);font-size:9px;color:var(--muted2);letter-spacing:.04em;margin-top:2px;}
.pc-tag{font-family:var(--mono);font-size:9px;padding:2px 6px;border:1px solid;flex-shrink:0;}
.pc-tag.pass{border-color:rgba(0,255,136,.3);color:var(--green);}
.pc-tag.fail{border-color:rgba(255,68,102,.3);color:var(--red);}
.pc-tag.warn{border-color:rgba(255,170,0,.3);color:var(--amber);}

@media(min-width:600px){.messages,.scroll-panel{padding:24px;}.input-area,.qcmds{padding-left:24px;padding-right:24px;}.bub{max-width:76%;font-size:14px;}}
</style>
</head>
<body>

<!-- API KEY MODAL -->
<div id="apiModal">
  <div class="api-logo">VAULT</div>
  <div class="api-subtitle">Private AI · Security Command Center v3.0</div>
  <div class="api-box">
    <div class="api-label">ANTHROPIC API KEY — SESSION ONLY · NEVER STORED</div>
    <div class="api-input-wrap">
      <div class="api-prefix">KEY▶</div>
      <input type="password" id="apiKeyInput" placeholder="sk-ant-api03-···" autocomplete="off" spellcheck="false"/>
      <button class="api-toggle" onclick="toggleKeyVis()" id="eyeBtn">👁</button>
    </div>
    <button class="api-submit" id="apiSubmit" onclick="submitKey()">[ INITIALIZE VAULT ]</button>
    <div class="api-err" id="apiErr">⚠ Invalid key format — must start with sk-ant-</div>
    <div class="api-warn">⚠ KEY HELD IN MEMORY ONLY · CLEARS ON RELOAD · NEVER LOGGED</div>
  </div>
</div>

<!-- BOOT -->
<div id="boot">
  <div class="boot-logo">VAULT</div>
  <div class="boot-tagline">Security Command Center · v3.0 · PWA</div>
  <div class="boot-log" id="bLog"></div>
  <div class="boot-prog"><div class="boot-prog-fill" id="bProg"></div></div>
  <button class="boot-enter" id="bEnter" onclick="launch()">[ TAP TO ENTER ]</button>
</div>

<!-- TOPBAR -->
<div class="topbar">
  <div class="tb-logo">VAULT</div>
  <div class="tb-session" id="sessId">···</div>
  <div class="tb-right">
    <div class="vpn-badge off" id="vpnBadge">🔒 VPN:?</div>
    <div class="loc-badge off" id="locBadge" onclick="switchTab('location')">
      <div class="loc-dot"></div>
      <span id="locBadgeText">LOC:OFF</span>
    </div>
  </div>
</div>

<!-- TABS -->
<div class="tabs">
  <div class="tab active" onclick="switchTab('chat')" id="tab-chat"><div class="tab-icon">💬</div><span>CHAT</span></div>
  <div class="tab" onclick="switchTab('watchdog')" id="tab-watchdog"><div class="tab-icon">🐕</div><span>WATCHDOG</span></div>
  <div class="tab" onclick="switchTab('threats')" id="tab-threats"><div class="tab-icon">🚨</div><span>THREATS</span></div>
  <div class="tab" onclick="switchTab('network')" id="tab-network"><div class="tab-icon">📡</div><span>NETWORK</span></div>
  <div class="tab" onclick="switchTab('darkweb')" id="tab-darkweb"><div class="tab-icon">🕵️</div><span>DARK WEB</span></div>
  <div class="tab" onclick="switchTab('location')" id="tab-location"><div class="tab-icon">📍</div><span>LOCATION</span></div>
  <div class="tab" onclick="switchTab('notes')" id="tab-notes"><div class="tab-icon">🔒</div><span>NOTES</span></div>
  <div class="tab" onclick="switchTab('privacy')" id="tab-privacy"><div class="tab-icon">🛡️</div><span>PRIVACY</span></div>
</div>

<!-- ═══ CHAT PANEL ═══ -->
<div class="panel active" id="panel-chat">
  <div class="qcmds">
    <div class="qc" onclick="qs('Harden my Samsung S24 FE security settings step by step')">/harden</div>
    <div class="qc" onclick="qs('Which apps on Android are most likely tracking me right now?')">/audit</div>
    <div class="qc" onclick="qs('How do I completely delete my digital footprint?')">/ghost</div>
    <div class="qc" onclick="qs('What is the best VPN for privacy in 2026?')">/vpn</div>
    <div class="qc" onclick="qs('Explain end-to-end encryption and how to use it')">/e2e</div>
    <div class="qc" onclick="qs('What are the most dangerous Android permissions to grant?')">/perms</div>
    <div class="qc" onclick="qs('How do I detect if my phone has been compromised?')">/scan</div>
    <div class="qc" onclick="qs('Explain the latest Android CVEs and how to stay safe')">/cve</div>
  </div>
  <div class="messages" id="msgs"></div>
  <div class="input-area">
    <div class="input-wrap">
      <div class="input-tag">CMD▶</div>
      <textarea id="inp" placeholder="Secure message or /command…" rows="1" onkeydown="onKey(event)" oninput="resize(this)"></textarea>
      <button class="send-btn" id="sendBtn" onclick="send()">
        <svg class="si" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
    <div class="input-foot">
      <div class="if-dot"></div><span>E2E ENCRYPTED</span><span>·</span><span>0-RETENTION</span>
      <span style="margin-left:auto;color:var(--cyan);">VAULT v3.0</span>
    </div>
  </div>
</div>

<!-- ═══ WATCHDOG PANEL ═══ -->
<div class="panel" id="panel-watchdog">
  <div class="scroll-panel">
    <div class="card red">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
        <div class="watch-pulse" id="wdPulse"></div>
        <div style="font-family:var(--head);font-size:16px;font-weight:600;letter-spacing:.1em;" id="wdTitle">WATCHDOG ACTIVE</div>
        <div style="margin-left:auto;font-family:var(--mono);font-size:9px;color:var(--muted2);" id="wdUptime">00:00:00</div>
      </div>
      <div class="wd-stats">
        <div class="wstat"><div class="wstat-num" id="wdTotal">0</div><div class="wstat-label">EVENTS</div></div>
        <div class="wstat"><div class="wstat-num amber" id="wdWarnings">0</div><div class="wstat-label">WARNINGS</div></div>
        <div class="wstat"><div class="wstat-num red" id="wdBlocked">0</div><div class="wstat-label">BLOCKED</div></div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Permission Status <span class="badge" id="permScanTime">SCANNING…</span></div>
      <div id="permList"></div>
      <button class="action-btn cyan" style="margin-top:12px;" onclick="scanPermissions()">🔍 RESCAN PERMISSIONS</button>
    </div>

    <div class="card">
      <div class="card-title">Live Event Feed <span class="badge" id="eventCount">0 EVENTS</span></div>
      <div class="mini-log" id="eventFeed">
        <div class="log-line"><span class="log-time">--:--:--</span><span class="log-text">Watchdog initialized — monitoring active…</span></div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Monitoring Controls</div>
      <div class="toggle-row">
        <div><div class="toggle-label">Monitor clipboard access</div><div class="toggle-sub">Alert on background clipboard reads</div></div>
        <div class="tog on" id="tog-clip" onclick="toggleWD(this,'clip')"><div class="tog-knob"></div></div>
      </div>
      <div class="toggle-row">
        <div><div class="toggle-label">Monitor network requests</div><div class="toggle-sub">Flag suspicious outbound connections</div></div>
        <div class="tog on" id="tog-net" onclick="toggleWD(this,'net')"><div class="tog-knob"></div></div>
      </div>
      <div class="toggle-row">
        <div><div class="toggle-label">Monitor battery drain</div><div class="toggle-sub">Detect background activity spikes</div></div>
        <div class="tog on" id="tog-batt" onclick="toggleWD(this,'batt')"><div class="tog-knob"></div></div>
      </div>
    </div>
    <button class="action-btn kill" onclick="clearWatchdog()">🗑 CLEAR EVENT LOG</button>
  </div>
</div>

<!-- ═══ THREATS PANEL ═══ -->
<div class="panel" id="panel-threats">
  <div class="scroll-panel">
    <div class="card red">
      <div style="display:flex;gap:14px;align-items:center;">
        <div style="font-family:var(--head);font-size:52px;font-weight:700;color:var(--red);line-height:1;" id="threatCount">—</div>
        <div>
          <div style="font-family:var(--head);font-size:15px;font-weight:600;letter-spacing:.08em;">ACTIVE THREATS</div>
          <div style="font-family:var(--mono);font-size:9px;color:var(--muted2);margin-top:4px;line-height:1.5;" id="threatSubtext">Loading Android CVE data…</div>
        </div>
      </div>
    </div>
    <button class="action-btn cyan" onclick="loadThreats()" id="refreshThreatsBtn">🔄 REFRESH THREAT FEED</button>
    <div id="cveList"></div>
    <button class="action-btn go" onclick="qs('Analyze these CVEs and tell me which ones affect Samsung S24 FE running Android 16 and how to mitigate them')">🤖 AI THREAT ANALYSIS</button>
  </div>
</div>

<!-- ═══ NETWORK PANEL ═══ -->
<div class="panel" id="panel-network">
  <div class="scroll-panel">
    <div class="card">
      <div class="card-title">Connection Status</div>
      <div class="net-stat-grid">
        <div class="net-stat"><div class="net-stat-label">CONNECTION</div><div class="net-stat-val" id="netType">—</div></div>
        <div class="net-stat"><div class="net-stat-label">VPN STATUS</div><div class="net-stat-val" id="netVpn">CHECKING…</div></div>
        <div class="net-stat"><div class="net-stat-label">DOWNLINK</div><div class="net-stat-val" id="netDown">—</div></div>
        <div class="net-stat"><div class="net-stat-label">LATENCY</div><div class="net-stat-val" id="netRtt">—</div></div>
        <div class="net-stat"><div class="net-stat-label">ONLINE</div><div class="net-stat-val green" id="netOnline">YES</div></div>
        <div class="net-stat"><div class="net-stat-label">SAVE DATA</div><div class="net-stat-val" id="netSave">—</div></div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">DNS Leak Test</div>
      <div style="font-family:var(--mono);font-size:11px;color:var(--muted2);margin-bottom:12px;line-height:1.6;">Tests whether your DNS queries are leaking outside your VPN tunnel. If DNS servers shown are NOT from your VPN provider, you have a leak.</div>
      <button class="action-btn cyan" onclick="runDnsTest()" id="dnsTestBtn">🔍 RUN DNS LEAK TEST</button>
      <div id="dnsResult" style="margin-top:12px;font-family:var(--mono);font-size:11px;display:none;"></div>
    </div>

    <div class="card">
      <div class="card-title">WebRTC Leak Check</div>
      <div style="font-family:var(--mono);font-size:11px;color:var(--muted2);margin-bottom:12px;line-height:1.6;">WebRTC can expose your real IP even when using a VPN. Detected local IPs are shown below.</div>
      <button class="action-btn cyan" onclick="runWebRTCCheck()" id="webrtcBtn">🔍 CHECK WEBRTC LEAKS</button>
      <div id="webrtcResult" style="margin-top:12px;font-family:var(--mono);font-size:11px;display:none;"></div>
    </div>

    <div class="card">
      <div class="card-title">Network Log <span class="badge" id="netLogCount">0 EVENTS</span></div>
      <div class="mini-log" id="netLog">
        <div class="log-line"><span class="log-time">--:--:--</span><span class="log-text">Network monitor initialized…</span></div>
      </div>
    </div>
    <button class="action-btn go" onclick="qs('My network connection type is '+document.getElementById(\'netType\').textContent+\' with VPN status: \'+document.getElementById(\'netVpn\').textContent+\'. Analyze my network security and give recommendations.')">🤖 AI NETWORK ANALYSIS</button>
  </div>
</div>

<!-- ═══ DARK WEB PANEL ═══ -->
<div class="panel" id="panel-darkweb">
  <div class="scroll-panel">
    <div class="card red">
      <div style="font-family:var(--head);font-size:15px;font-weight:600;letter-spacing:.08em;margin-bottom:6px;">DARK WEB SCANNER</div>
      <div style="font-family:var(--mono);font-size:10px;color:var(--muted2);line-height:1.6;">Check if your email addresses have appeared in known data breaches using the HaveIBeenPwned database. Enter each email you want to scan.</div>
    </div>

    <div class="card">
      <div class="card-title">Scan Email Address</div>
      <div class="scan-input-wrap">
        <input type="email" class="scan-input" id="breachEmail" placeholder="your@email.com" autocomplete="off"/>
        <button class="scan-btn" onclick="scanBreach()" id="scanBreachBtn">SCAN</button>
      </div>
      <div id="breachResult"></div>
    </div>

    <div class="card">
      <div class="card-title">Scan History <span class="badge" id="scanHistoryCount">0 SCANS</span></div>
      <div id="scanHistory"><div style="font-family:var(--mono);font-size:10px;color:var(--muted2);">No scans yet — enter an email above to begin.</div></div>
    </div>

    <div class="card">
      <div class="card-title">Password Breach Check</div>
      <div style="font-family:var(--mono);font-size:10px;color:var(--muted2);margin-bottom:12px;line-height:1.6;">Check if a password has appeared in known breaches. Uses k-anonymity — only the first 5 chars of the hash are sent.</div>
      <div class="scan-input-wrap">
        <input type="password" class="scan-input" id="pwdInput" placeholder="Enter password to check…" autocomplete="off"/>
        <button class="scan-btn" onclick="checkPassword()" id="checkPwdBtn">CHECK</button>
      </div>
      <div id="pwdResult"></div>
    </div>
    <button class="action-btn go" onclick="qs('My dark web scan is complete. Explain what I should do if my email was found in a data breach, step by step.')">🤖 AI BREACH RESPONSE GUIDE</button>
  </div>
</div>

<!-- ═══ LOCATION PANEL ═══ -->
<div class="panel" id="panel-location">
  <div class="scroll-panel">
    <div class="card">
      <div class="loc-hero">
        <div class="loc-ring">
