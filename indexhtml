<script>
// ══════════════════════════════════
// STATE
// ══════════════════════════════════
const S = {
  msgs: [],
  thinking: false,
  locMode: 'off',
  spoofCity: null,
  realCoords: null,
  logLines: [],
  logCount: 0,
  toggState: { gps: true, ip: true, alert: true },
