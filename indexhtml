  {name:'Clipboard Read',icon:'📋',perm:'clipboard-read',risk:'medium'},
  {name:'Persistent Storage',icon:'💾',perm:'persistent-storage',risk:'low'},
  {name:'Ambient Light',icon:'💡',perm:'ambient-light-sensor',risk:'low'},
  {name:'Accelerometer',icon:'📱',perm:'accelerometer',risk:'medium'},
];

async function scanPermissions(){
  document.getElementById('permScanTime').textContent='SCANNING…';
  const list=document.getElementById('permList');list.innerHTML='';
  let granted=0;
  for(const p of PERMISSIONS_TO_CHECK){
    let state='unknown';
    try{const r=await navigator.permissions.query({name:p.perm});state=r.state;}catch(e){}
    if(state==='granted')granted++;
    const div=document.createElement('div');div.className='perm-item';
    const riskColor=state==='granted'?(p.risk==='high'?'red':'amber'):'';
    div.innerHTML=`<div class="perm-icon">${p.icon}</div><div class="perm-info"><div class="perm-name">${p.name}</div><div class="perm-state">${p.perm} · risk: ${p.risk}</div></div><div class="perm-badge ${state}">${state.toUpperCase()}</div>`;
    list.appendChild(div);
    if(state==='granted'&&p.risk==='high'){addWDEvent(`⚠ HIGH RISK: ${p.name} permission is GRANTED`,'warn');S.wdWarnings++;}
  }
  document.getElementById('permScanTime').textContent=`${ts()} · ${granted} GRANTED`;
  addWDEvent(`Permission scan complete — ${granted} permissions granted`,'ok');
  updateWDStats();
}

function addWDEvent(text,cls=''){
  S.wdEvents.push({text,cls,time:ts()});
  if(cls==='warn')S.wdWarnings++;
  if(cls==='block')S.wdBlocked++;
  const feed=document.getElementById('eventFeed');
  if(feed.children.length===1&&feed.children[0].querySelector('.log-text')?.textContent.includes('Watchdog initialized'))feed.innerHTML='';
  const line=document.createElement('div');line.className='log-line';
  line.innerHTML=`<span class="log-time">${ts()}</span><span class="log-text ${cls}">${text}</span>`;
  feed.insertBefore(line,feed.firstChild);
  if(feed.children.length>30)feed.removeChild(feed.lastChild);
  updateWDStats();
}

function updateWDStats(){
  document.getElementById('wdTotal').textContent=S.wdEvents.length;
  document.getElementById('wdWarnings').textContent=S.wdWarnings;
  document.getElementById('wdBlocked').textContent=S.wdBlocked;
  document.getElementById('eventCount').textContent=S.wdEvents.length+' EVENTS';
}

function toggleWD(el,key){S.wdToggles[key]=!S.wdToggles[key];el.classList.toggle('on',S.wdToggles[key]);addWDEvent(key.toUpperCase()+' monitoring '+(S.wdToggles[key]?'ENABLED':'DISABLED'),S.wdToggles[key]?'ok':'warn');}
function clearWatchdog(){S.wdEvents=[];S.wdWarnings=0;S.wdBlocked=0;document.getElementById('eventFeed').innerHTML='<div class="log-line"><span class="log-time">--:--:--</span><span class="log-text">Log cleared.</span></div>';updateWDStats();}

function startWatchdog(){
  scanPermissions();
  // Uptime counter
  setInterval(()=>{
    const s=Math.floor((Date.now()-S.wdStart)/1000);
    const h=String(Math.floor(s/3600)).padStart(2,'0');
    const m=String(Math.floor((s%3600)/60)).padStart(2,'0');
    const sec=String(s%60).padStart(2,'0');
    document.getElementById('wdUptime').textContent=`${h}:${m}:${sec}`;
  },1000);
  // Periodic checks
  setInterval(()=>{
    if(S.wdToggles.net&&Math.random()<0.3){addWDEvent('Network activity check — nominal','ok');}
    if(S.wdToggles.batt&&'getBattery' in navigator){navigator.getBattery().then(b=>{if(b.level<0.2&&!b.charging)addWDEvent(`⚠ Low battery (${Math.round(b.level*100)}%) — background activity may increase`,'warn');});}
  },30000);
  // Clipboard monitoring
  document.addEventListener('copy',()=>addWDEvent('Clipboard WRITE detected','warn'));
  document.addEventListener('paste',()=>addWDEvent('Clipboard READ detected','warn'));
  addWDEvent('Watchdog daemon started — all monitors active','ok');
}

