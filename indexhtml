function setLocMode(mode){
  S.locMode=mode;
  if(mode==='live'){
    if(navigator.geolocation){navigator.geolocation.getCurrentPosition(pos=>{S.realCoords={lat:pos.coords.latitude,lng:pos.coords.longitude,acc:pos.coords.accuracy};updateLocUI();addLocLog('GPS access GRANTED — real coords loaded','warn');addWDEvent('⚠ LIVE GPS activated — real location exposed','block');},()=>{addLocLog('GPS access denied','block');S.locMode='off';updateLocUI();});}
