// ── PWA INSTALL PROMPT ──
let deferredPrompt;
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  // Show install banner in topbar after boot
  setTimeout(() => {
    const tb = document.querySelector('.tb-right');
    if(!tb || document.querySelector('#installBtn')) return;
    const btn = document.createElement('button');
    btn.id = 'installBtn';
    btn.style.cssText = 'font-family:var(--mono);font-size:9px;letter-spacing:.06em;padding:4px 8px;border:1px solid rgba(0,229,255,0.4);color:var(--cyan);background:rgba(0,229,255,0.06);cursor:pointer;';
    btn.textContent = '⬇ INSTALL';
    btn.onclick = () => {
      deferredPrompt.prompt();
      deferredPrompt.userChoice.then(() => { btn.remove(); deferredPrompt=null; });
    };
    tb.insertBefore(btn, tb.firstChild);
  }, 4000);
});

// ── WAKE LOCK: prevent screen/CPU sleep ──
let wakeLock = null;
async function requestWakeLock(){
  try {
    if('wakeLock' in navigator){
      wakeLock = await navigator.wakeLock.request('screen');
    }
  } catch(e){}
}
document.addEventListener('visibilitychange', async () => {
  if(document.visibilityState === 'visible') await requestWakeLock();
});
requestWakeLock();

// Init loc UI
updateLocUI();
</script>
<script>
// ── INLINE MANIFEST ──
(function(){
  const manifest = '{\n  "name": "VAULT — Private AI",\n  "short_name": "VAULT",\n  "description": "Private AI security and privacy command interface",\n  "start_url": "/",\n  "display": "standalone",\n  "orientation": "portrait",\n  "background_color": "#080910",\n  "theme_color": "#080910",\n  "icons": [\n    {"src": "data:image/png;base64,", "sizes": "192x192", "type": "image/png", "purpose": "any maskable"},\n    {"src": "data:image/png;base64,", "sizes": "512x512", "type": "image/png", "purpose": "any maskable"}\n  ]\n}';
  const blob = new Blob([manifest], {type:'application/json'});
  const url = URL.createObjectURL(blob);
  const el = document.querySelector('link[rel="manifest"]');
  if(el) el.href = url;
})();

// ── INLINE SERVICE WORKER ──
(function(){
  if(!('serviceWorker' in navigator)) return;
  const swCode = `// VAULT Service Worker v1.0
// Handles caching, background sync, and keep-alive

const CACHE = 'vault-v1';
const ASSETS = [
  '/',
  '/index.html',
  '/manifest.json',
  'https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Courier+Prime:wght@400;700&family=Sora:wght@300;400;500&display=swap'
];

// ── INSTALL: cache all static assets ──
self.addEventListener('install', e => {
  self.skipWaiting();
  e.waitUntil(
    caches.open(CACHE).then(cache => {
      return Promise.allSettled(
        ASSETS.map(url => cache.add(url).catch(() => {}))
      );
    })
  );
});

// ── ACTIVATE: clean old caches ──
self.addEventListener('activate', e => {
  e.waitUntil(
    caches.keys().then(keys =>
      Promise.all(keys.filter(k => k !== CACHE).map(k => caches.delete(k)))
    ).then(() => self.clients.claim())
  );
});

// ── FETCH: serve from cache, fall back to network ──
self.addEventListener('fetch', e => {
  // Never intercept Anthropic API calls — always go live
  if (e.request.url.includes('api.anthropic.com')) return;
  // Never intercept Google Fonts loading
  if (e.request.url.includes('fonts.gstatic.com')) return;

  e.respondWith(
    caches.match(e.request).then(cached => {
      if (cached) return cached;
      return fetch(e.request).then(res => {
        // Cache successful GET responses
        if (e.request.method === 'GET' && res.status === 200) {
          const copy = res.clone();
          caches.open(CACHE).then(c => c.put(e.request, copy));
        }
        return res;
      }).catch(() => {
        // Offline fallback — serve index.html for navigation requests
        if (e.request.mode === 'navigate') {
          return caches.match('/index.html');
        }
      });
    })
  );
});

// ── BACKGROUND SYNC: keep alive ping ──
self.addEventListener('sync', e => {
  if (e.tag === 'vault-keepalive') {
    e.waitUntil(Promise.resolve());
  }
});

// ── PUSH: future notification support ──
self.addEventListener('push', e => {
  if (!e.data) return;
  const data = e.data.json();
  self.registration.showNotification(data.title || 'VAULT', {
    body: data.body || 'Security alert',
    icon: '/icon-192.png',
    badge: '/icon-192.png',
    tag: 'vault-alert',
    renotify: true,
    data: { url: data.url || '/' }
  });
});

self.addEventListener('notificationclick', e => {
  e.notification.close();
  e.waitUntil(
    clients.matchAll({ type: 'window' }).then(list => {
      if (list.length) return list[0].focus();
      return clients.openWindow('/');
    })
  );
});
`;
  const blob = new Blob([swCode], {type:'application/javascript'});
  const url = URL.createObjectURL(blob);
  navigator.serviceWorker.register(url, {scope:'/'}).then(reg => {
    setInterval(() => { if(reg.active) reg.active.postMessage('ping'); }, 20000);
  }).catch(()=>{});
})();
</script>
