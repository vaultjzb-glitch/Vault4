  PRIV_CHECKS.forEach((c,i)=>{if(i===2){if(S.locMode==='off')score++;else if(S.locMode==='mask')score+=0.5;}else if(c.status==='pass')score++;else if(c.status==='warn')score+=0.5;});
  const pct=Math.round((score/total)*100);
  document.getElementById('scoreNum').textContent=pct;
  const ring=document.getElementById('scoreRing');
  ring.style.strokeDashoffset=188.5-(188.5*(pct/100));
  const col=pct>=75?'var(--green)':pct>=50?'var(--amber)':'var(--red)';
  ring.style.stroke=col;
  document.getElementById('scoreNum').style.color=col;
  const title=pct>=75?'GOOD':pct>=50?'FAIR':'AT RISK';
  document.getElementById('scoreTitle').textContent=title;
  document.getElementById('scoreTitle').style.color=col;
}

