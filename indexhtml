const PERMISSIONS_TO_CHECK=[
  {name:'Camera',icon:'📷',perm:'camera',risk:'high'},
  {name:'Microphone',icon:'🎙️',perm:'microphone',risk:'high'},
  {name:'Geolocation',icon:'📍',perm:'geolocation',risk:'high'},
