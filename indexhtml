// ══════════════════════════════════
// LOCATION
// ══════════════════════════════════
function addLog(text, cls=''){
  S.logCount++;
  document.getElementById('logCount').textContent = S.logCount+' EVENTS';
  const log=document.getElementById('locLog');
  if(log.children.length===1 && log.children[0].querySelector('.log-text').textContent.includes('Awaiting')) log.innerHTML='';
  const t=ts();
  const line=document.createElement('div'); line.className='log-line';
  line.innerHTML=`<span class="log-time">${t}</span><span class="log-text ${cls}">${text}</span>`;
  log.insertBefore(line,log.firstChild);
  if(log.children.length>20) log.removeChild(log.lastChild);
}

function updateLocUI(){
  const badge=document.getElementById('locBadge');
  const badgeText=document.getElementById('locBadgeText');
  const iconWrap=document.getElementById('locIconWrap');
  const iconEmoji=document.getElementById('locIconEmoji');
  const statusText=document.getElementById('locStatusText');
  const subText=document.getElementById('locSubText');

  // Reset classes
  badge.className='loc-badge';
  iconWrap.className='loc-icon-wrap';
  statusText.className='loc-status-text';

  if(S.locMode==='off'){
    badge.classList.add('off'); badgeText.textContent='LOC:OFF';
    iconWrap.classList.add('off'); iconEmoji.textContent='🚫';
    statusText.classList.add('off'); statusText.textContent='LOCATION DISABLED';
    subText.textContent='No location data is being accessed or shared';
    document.getElementById('coordLat').className='coord-val hidden'; document.getElementById('coordLat').textContent='██████████';
    document.getElementById('coordLng').className='coord-val hidden'; document.getElementById('coordLng').textContent='██████████';
    document.getElementById('coordAcc').className='coord-val hidden'; document.getElementById('coordAcc').textContent='██████████';
    document.getElementById('coordSrc').textContent='DISABLED'; document.getElementById('coordSrc').style.color='var(--muted2)';
    document.getElementById('spoofCard').style.display='none';
  } else if(S.locMode==='mask'){
    badge.classList.add('masked'); badgeText.textContent='LOC:MASK';
    iconWrap.classList.add('masked'); iconEmoji.textContent='🎭';
    statusText.classList.add('masked'); statusText.textContent='LOCATION SPOOFED';
    const c=S.spoofCity;
    subText.textContent=c?`Broadcasting as ${c.city}, ${c.country}`:'Select a spoof city below';
    if(c){
      document.getElementById('coordLat').className='coord-val spoofed'; document.getElementById('coordLat').textContent=c.lat.toFixed(4)+'° (FAKE)';
      document.getElementById('coordLng').className='coord-val spoofed'; document.getElementById('coordLng').textContent=c.lng.toFixed(4)+'° (FAKE)';
      document.getElementById('coordAcc').className='coord-val spoofed'; document.getElementById('coordAcc').textContent='~15m (INJECTED)';
      document.getElementById('coordSrc').textContent='SPOOFED'; document.getElementById('coordSrc').style.color='var(--green)';
    }
    document.getElementById('spoofCard').style.display='';
  } else {
    badge.classList.add('live'); badgeText.textContent='LOC:LIVE';
    iconWrap.classList.add('live'); iconEmoji.textContent='📡';
    statusText.classList.add('live'); statusText.textContent='LIVE GPS ACTIVE';
    subText.textContent='Real GPS coordinates are being used — use with caution';
    document.getElementById('spoofCard').style.display='none';
    if(S.realCoords){
      document.getElementById('coordLat').className='coord-val'; document.getElementById('coordLat').style.color='var(--red)';
      document.getElementById('coordLat').textContent=S.realCoords.lat.toFixed(5)+'°';
      document.getElementById('coordLng').className='coord-val'; document.getElementById('coordLng').style.color='var(--red)';
      document.getElementById('coordLng').textContent=S.realCoords.lng.toFixed(5)+'°';
      document.getElementById('coordAcc').className='coord-val'; document.getElementById('coordAcc').style.color='var(--amber)';
      document.getElementById('coordAcc').textContent='~'+Math.round(S.realCoords.acc||20)+'m';
      document.getElementById('coordSrc').textContent='REAL GPS'; document.getElementById('coordSrc').style.color='var(--red)';
    }
  }

  // Mode buttons
  ['off','mask','live'].forEach(m=>{
    const btn=document.getElementById('mode-'+m);
    btn.className='mode-btn';
    if(m===S.locMode){
      const clr=m==='off'?'grey':m==='mask'?'green':'red';
      btn.classList.add('active',clr);
    }
  });

  // Privacy check update
  const pcLoc=document.getElementById('pc-loc');
  if(pcLoc){
    const icon=pcLoc.querySelector('.pc-icon');
    const tag=pcLoc.querySelector('.pc-tag');
    const sub=pcLoc.querySelector('.pc-sub');
    if(S.locMode==='off'){
      icon.className='pc-icon pass'; icon.textContent='🔐';
      tag.className='pc-tag pass'; tag.textContent='BLOCKED';
      sub.textContent='GPS access currently disabled';
    } else if(S.locMode==='mask'){
      icon.className='pc-icon warn'; icon.textContent='🎭';
      tag.className='pc-tag warn'; tag.textContent='SPOOFED';
      sub.textContent=`Broadcasting fake location: ${S.spoofCity?.city||'?'}`;
    } else {
      icon.className='pc-icon fail'; icon.textContent='⚠️';
      tag.className='pc-tag fail'; tag.textContent='EXPOSED';
      sub.textContent='Real GPS coordinates are being shared';
    }
  }
  updateScore();
}

function setLocMode(mode){
  const prev=S.locMode;
  S.locMode=mode;
  if(mode==='live'){
    if(navigator.geolocation){
      navigator.geolocation.getCurrentPosition(
        pos=>{ S.realCoords={lat:pos.coords.latitude,lng:pos.coords.longitude,acc:pos.coords.accuracy}; updateLocUI(); addLog('GPS access GRANTED — real coords loaded','warn'); },
        ()=>{ addLog('GPS access denied by browser','block'); S.locMode='off'; updateLocUI(); }
      );
    } else { addLog('Geolocation API not available','block'); S.locMode='off'; }
  } else if(mode==='mask'){
    addLog('Location spoofing ACTIVATED','ok');
    if(!S.spoofCity){ S.spoofCity=SPOOF_LOCS[0]; }
  } else {
    addLog('Location access DISABLED — fully blocked','ok');
  }
  updateLocUI();
}

function buildSpoofGrid(){
  const grid=document.getElementById('spoofGrid');
  grid.innerHTML='';
  SPOOF_LOCS.forEach(loc=>{
    const el=document.createElement('div');
    el.className='spoof-loc'+(S.spoofCity===loc?' selected':'');
    el.innerHTML=`<div class="sl-city">${loc.city}, ${loc.country}</div><div class="sl-coords">${loc.lat.toFixed(2)}, ${loc.lng.toFixed(2)}</div>`;
    el.onclick=()=>{ S.spoofCity=loc; buildSpoofGrid(); updateLocUI(); addLog(`Spoof location set to ${loc.city}, ${loc.country}`,'ok'); };
    grid.appendChild(el);
  });
}
buildSpoofGrid();

function toggle(el, key){
  S.toggState[key]=!S.toggState[key];
  el.classList.toggle('on', S.toggState[key]);
  addLog(key.toUpperCase()+' blocking '+(S.toggState[key]?'ENABLED':'DISABLED'), S.toggState[key]?'ok':'warn');
}

function killLocation(){
  S.locMode='off'; S.realCoords=null;
  ['gps','ip','alert'].forEach(k=>{ S.toggState[k]=true; document.getElementById('tog-'+k).classList.add('on'); });
  updateLocUI();
  addLog('⚡ EMERGENCY KILL SWITCH — All location access terminated','block');
  // Visual flash
  document.body.style.transition='background .1s';
  document.body.style.background='rgba(255,68,102,0.15)';
  setTimeout(()=>{ document.body.style.background=''; },200);
}

// ══════════════════════════════════
// PRIVACY SCORE
// ══════════════════════════════════
function updateScore(){
  let score=0, total=PRIV_CHECKS.length;
  PRIV_CHECKS.forEach((c,i)=>{
    if(i===2){
      if(S.locMode==='off') score++;
      else if(S.locMode==='mask') score+=0.5;
    } else if(c.status==='pass') score++;
    else if(c.status==='warn') score+=0.5;
  });
  const pct=Math.round((score/total)*100);
  document.getElementById('scoreNum').textContent=pct;
  const ring=document.getElementById('scoreRing');
  const offset=188.5-(188.5*(pct/100));
  ring.style.strokeDashoffset=offset;
  ring.style.stroke=pct>=75?'var(--green)':pct>=50?'var(--amber)':'var(--red)';
  document.getElementById('scoreNum').style.color=pct>=75?'var(--green)':pct>=50?'var(--amber)':'var(--red)';
}

function initPrivChecks(){
  const c=document.getElementById('privChecks');
  c.innerHTML='';
  PRIV_CHECKS.forEach((check,i)=>{
    const el=document.createElement('div');
    el.className='priv-check';
    if(i===2) el.id='pc-loc';
    el.innerHTML=`
      <div class="pc-icon ${check.status}">${check.icon}</div>
      <div class="pc-text">
        <div class="pc-title">${check.title}</div>
        <div class="pc-sub">${check.sub}</div>
      </div>
      <div class="pc-tag ${check.status}">${check.tag}</div>
    `;
    c.appendChild(el);
  });
  updateScore();
}

