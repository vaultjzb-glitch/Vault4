function addNetLog(text,cls=''){
  S.netLogCount++;
  document.getElementById('netLogCount').textContent=S.netLogCount+' EVENTS';
  const log=document.getElementById('netLog');
  if(log.children.length===1&&log.children[0].querySelector('.log-text')?.textContent.includes('initialized'))log.innerHTML='';
  const line=document.createElement('div');line.className='log-line';
  line.innerHTML=`<span class="log-time">${ts()}</span><span class="log-text ${cls}">${text}</span>`;
  log.insertBefore(line,log.firstChild);
  if(log.children.length>20)log.removeChild(log.lastChild);
}

function checkNetwork(){
  const conn=navigator.connection||navigator.mozConnection||navigator.webkitConnection;
  if(conn){
    document.getElementById('netType').textContent=conn.effectiveType?.toUpperCase()||conn.type?.toUpperCase()||'UNKNOWN';
    document.getElementById('netDown').textContent=conn.downlink?conn.downlink+'Mbps':'—';
    document.getElementById('netRtt').textContent=conn.rtt?conn.rtt+'ms':'—';
    document.getElementById('netSave').textContent=conn.saveData?'ON':'OFF';
  }else{
    document.getElementById('netType').textContent='UNKNOWN';
  }
  // VPN heuristic — check if we can detect VPN-like characteristics
  detectVPN();
  document.getElementById('netOnline').textContent=navigator.onLine?'YES':'NO';
  document.getElementById('netOnline').className='net-stat-val '+(navigator.onLine?'green':'red');
  addNetLog('Network status check complete','ok');
  window.addEventListener('online',()=>{document.getElementById('netOnline').textContent='YES';document.getElementById('netOnline').className='net-stat-val green';addNetLog('Network connection restored','ok');});
  window.addEventListener('offline',()=>{document.getElementById('netOnline').textContent='NO';document.getElementById('netOnline').className='net-stat-val red';addNetLog('⚠ Network connection lost!','warn');});
}

function detectVPN(){
  // Heuristic VPN detection using timing and IP characteristics
  const start=performance.now();
  fetch('https://api.ipify.org?format=json',{signal:AbortSignal.timeout(5000)})
    .then(r=>r.json())
    .then(d=>{
      const latency=Math.round(performance.now()-start);
      const ip=d.ip||'';
      // High latency often indicates VPN routing
      const likelyVPN=latency>200;
      const vpnEl=document.getElementById('netVpn');
      const badgeEl=document.getElementById('vpnBadge');
      if(likelyVPN){
        vpnEl.textContent='LIKELY ACTIVE';vpnEl.className='net-stat-val green';
        badgeEl.textContent='🔒 VPN:ON';badgeEl.className='vpn-badge on';
        addNetLog(`VPN likely active — high latency detected (${latency}ms)`,'ok');
      }else{
        vpnEl.textContent='NOT DETECTED';vpnEl.className='net-stat-val red';
        badgeEl.textContent='⚠ VPN:OFF';badgeEl.className='vpn-badge off';
        addNetLog(`⚠ VPN not detected — direct connection (${latency}ms)`,'warn');
        addWDEvent('⚠ VPN not detected — IP may be exposed','warn');
      }
    })
    .catch(()=>{
      document.getElementById('netVpn').textContent='CHECK FAILED';
      document.getElementById('vpnBadge').textContent='🔒 VPN:?';
      addNetLog('VPN detection failed — network unreachable','warn');
    });
}

function runDnsTest(){
  document.getElementById('dnsTestBtn').textContent='TESTING…';
  document.getElementById('dnsResult').style.display='block';
  document.getElementById('dnsResult').innerHTML='<span style="color:var(--muted2);">Running DNS leak test…</span>';
  // Test DNS resolution timing to detect potential leaks
  const tests=['cloudflare.com','google.com','amazon.com'];
  const results=[];
  let completed=0;
  tests.forEach(host=>{
    const start=performance.now();
    fetch(`https://${host}/favicon.ico`,{mode:'no-cors',signal:AbortSignal.timeout(3000)})
      .then(()=>{results.push({host,time:Math.round(performance.now()-start),status:'resolved'});})
      .catch(()=>{results.push({host,time:Math.round(performance.now()-start),status:'failed'});})
      .finally(()=>{
        completed++;
        if(completed===tests.length){
          const avgTime=Math.round(results.reduce((a,b)=>a+b.time,0)/results.length);
          const leaked=avgTime<50; // Very fast resolution may indicate ISP DNS
          document.getElementById('dnsResult').innerHTML=results.map(r=>`<div style="margin:4px 0;"><span style="color:var(--muted);">${r.host}: </span><span style="color:${r.status==='resolved'?'var(--green)':'var(--red)'};">${r.time}ms</span></div>`).join('')+`<div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--s3);color:${leaked?'var(--amber)':'var(--green)'};">AVG: ${avgTime}ms — ${leaked?'⚠ POSSIBLE DNS LEAK — consider DNS-over-HTTPS':'✓ DNS timing normal'}</div>`;
          addNetLog(`DNS test complete — avg ${avgTime}ms ${leaked?'(possible leak)':'(normal)'}`,leaked?'warn':'ok');
          document.getElementById('dnsTestBtn').textContent='🔍 RUN DNS LEAK TEST';
        }
      });
  });
}

function runWebRTCCheck(){
  document.getElementById('webrtcBtn').textContent='CHECKING…';
  document.getElementById('webrtcResult').style.display='block';
  const ips=new Set();
  try{
    const pc=new RTCPeerConnection({iceServers:[{urls:'stun:stun.l.google.com:19302'}]});
    pc.createDataChannel('');
    pc.createOffer().then(o=>pc.setLocalDescription(o));
    pc.onicecandidate=e=>{
      if(!e.candidate)return;
      const m=e.candidate.candidate.match(/(\d+\.\d+\.\d+\.\d+)/g);
      if(m)m.forEach(ip=>ips.add(ip));
    };
    setTimeout(()=>{
      pc.close();
      const ipList=[...ips];
      const hasLocal=ipList.some(ip=>ip.startsWith('192.')||ip.startsWith('10.')||ip.startsWith('172.'));
      const hasPublic=ipList.some(ip=>!ip.startsWith('192.')&&!ip.startsWith('10.')&&!ip.startsWith('172.')&&ip!=='0.0.0.0');
      document.getElementById('webrtcResult').innerHTML=(ipList.length?ipList.map(ip=>{const isLocal=ip.startsWith('192.')||ip.startsWith('10.')||ip.startsWith('172.');return `<div style="margin:4px 0;"><span style="color:${isLocal?'var(--amber)':'var(--red)'};">${isLocal?'LOCAL':'PUBLIC'}</span> <span style="font-family:var(--mono);color:var(--text);">${ip}</span></div>`;}).join(''):`<div style="color:var(--green);">No IPs detected via WebRTC ✓</div>`)+(hasPublic?`<div style="margin-top:8px;color:var(--red);">⚠ PUBLIC IP LEAKED via WebRTC!</div>`:'');
      if(hasPublic){addNetLog('⚠ WebRTC PUBLIC IP leak detected!','block');addWDEvent('⚠ CRITICAL: WebRTC leaking real IP address','block');}else{addNetLog('WebRTC check complete — no public IP leak','ok');}
      document.getElementById('webrtcBtn').textContent='🔍 CHECK WEBRTC LEAKS';
    },3000);
  }catch(e){document.getElementById('webrtcResult').innerHTML='<span style="color:var(--muted2);">WebRTC not available in this browser</span>';document.getElementById('webrtcBtn').textContent='🔍 CHECK WEBRTC LEAKS';}
}

