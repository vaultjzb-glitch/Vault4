function ts(){return new Date().toLocaleTimeString('en-US',{hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'});}
function fmt(t){return t.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/`(.*?)`/g,`<code style="font-family:var(--mono);font-size:11px;color:var(--cyan);background:rgba(0,229,255,0.07);padding:1px 4px;">$1</code>`).replace(/\n/g,'<br>');}
function esc(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function scrollDown(){const m=document.getElementById('msgs');requestAnimationFrame(()=>m.scrollTop=m.scrollHeight);}
function sysMsg(t){const el=document.createElement('div');el.className='sys-msg';el.textContent=t;document.getElementById('msgs').appendChild(el);scrollDown();}
function userMsg(t){const el=document.createElement('div');el.className='msg user';el.innerHTML=`<div class="av user">YOU</div><div class="mb"><div class="bub">${esc(t)}</div><div class="msg-foot"><span class="enc">🔒</span><span>ENCRYPTED · ${ts()}</span></div></div>`;document.getElementById('msgs').appendChild(el);scrollDown();}
function showThink(){const el=document.createElement('div');el.className='msg ai';el.id='think';el.innerHTML=`<div class="av ai">AI</div><div class="mb"><div class="think-bub"><div class="td"></div><div class="td"></div><div class="td"></div></div></div>`;document.getElementById('msgs').appendChild(el);scrollDown();}
function rmThink(){const e=document.getElementById('think');if(e)e.remove();}
function aiMsg(t){rmThink();const el=document.createElement('div');el.className='msg ai';el.innerHTML=`<div class="av ai">AI</div><div class="mb"><div class="bub">${fmt(t)}</div><div class="msg-foot"><span class="enc">🔒</span><span>AES-256 · LOCAL · ${ts()}</span></div></div>`;document.getElementById('msgs').appendChild(el);scrollDown();}
function streamStart(){rmThink();const el=document.createElement('div');el.className='msg ai';el.id='streamEl';el.innerHTML=`<div class="av ai">AI</div><div class="mb"><div class="bub" id="streamBub"><span class="cursor"></span></div><div class="msg-foot"><span class="enc">🔒</span><span>STREAMING · ${ts()}</span></div></div>`;document.getElementById('msgs').appendChild(el);scrollDown();return document.getElementById('streamBub');}
function streamEnd(){const el=document.getElementById('streamEl');if(!el)return;el.removeAttribute('id');const c=el.querySelector('.cursor');if(c)c.remove();}
function qs(t){switchTab('chat');document.getElementById('inp').value=t;send();}

async function send(){
  const inp=document.getElementById('inp'),t=inp.value.trim();
  if(!t||S.thinking)return;
  S.thinking=true;inp.value='';inp.style.height='auto';
  document.getElementById('sendBtn').disabled=true;
  userMsg(t);S.msgs.push({role:'user',content:t});showThink();
  const locCtx=S.locMode==='mask'?`Location: SPOOFED as ${S.spoofCity?.city||'unknown'}.`:S.locMode==='live'?'Location: LIVE GPS active.':'Location: FULLY DISABLED.';
  const netCtx=`Network: ${document.getElementById('netType').textContent}, VPN: ${document.getElementById('netVpn').textContent}.`;
  const wdCtx=`Watchdog: ${S.wdEvents.length} events, ${S.wdWarnings} warnings, ${S.wdBlocked} blocked.`;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':VAULT_KEY,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1024,system:`You are VAULT, an elite private AI security command center. Device: Samsung S24 FE running Android 16. ${locCtx} ${netCtx} ${wdCtx} You specialize in mobile security, privacy, threat intelligence, CVE analysis, network security, dark web monitoring, and device hardening. Be precise, tactical, and actionable. Use **bold** for key terms. Keep responses sharp and impactful. Think like a top-tier security operative protecting a high-value target.`,messages:S.msgs,stream:true})});
    if(!res.ok)throw new Error('HTTP '+res.status);
    const bub=streamStart();let full='',disp='';
    const reader=res.body.getReader(),dec=new TextDecoder();
    while(true){const{done,value}=await reader.read();if(done)break;const chunk=dec.decode(value,{stream:true});for(const line of chunk.split('\n')){if(!line.startsWith('data: '))continue;const d=line.slice(6).trim();if(d==='[DONE]')continue;try{const j=JSON.parse(d);if(j.type==='content_block_delta'&&j.delta?.text){full+=j.delta.text;disp+=j.delta.text;bub.innerHTML=fmt(disp)+'<span class="cursor"></span>';scrollDown();}}catch{}}}
    streamEnd();S.msgs.push({role:'assistant',content:full});
  }catch(e){rmThink();aiMsg(`**[CONNECTION ERROR]**\n\nCould not reach AI backend.\n\`${e.message}\``);}
  S.thinking=false;document.getElementById('sendBtn').disabled=false;
}
function onKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send();}}
