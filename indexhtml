  { city: 'Zurich', country: 'CH', lat: 47.3769, lng: 8.5417 },
  { city: 'Oslo', country: 'NO', lat: 59.9139, lng: 10.7522 },
];

const PRIV_CHECKS = [
  { icon:'🔐', title:'End-to-end encryption', sub:'All messages encrypted AES-256', status:'pass', tag:'ACTIVE' },
  { icon:'🧹', title:'Zero data retention', sub:'No chat history stored on servers', status:'pass', tag:'ACTIVE' },
  { icon:'📍', title:'Location services', sub:'GPS access currently disabled', status:'pass', tag:'BLOCKED', id:'pc-loc' },
  { icon:'🍪', title:'Tracking cookies', sub:'Cross-site tracking intercepted', status:'pass', tag:'BLOCKED' },
  { icon:'🌐', title:'VPN / IP masking', sub:'Direct IP may be exposed', status:'warn', tag:'REVIEW' },
  { icon:'📷', title:'Camera access', sub:'No camera permissions granted', status:'pass', tag:'BLOCKED' },
  { icon:'🎙️', title:'Microphone access', sub:'No microphone permissions granted', status:'pass', tag:'BLOCKED' },
  { icon:'☁️', title:'Cloud sync', sub:'Data sync to cloud is disabled', status:'pass', tag:'DISABLED' },
];

// ══════════════════════════════════
// API KEY GATE
// ══════════════════════════════════
let VAULT_KEY = '';

function toggleKeyVis() {
  const inp = document.getElementById('apiKeyInput');
  const btn = document.getElementById('eyeBtn');
  if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; }
  else { inp.type = 'password'; btn.textContent = '👁'; }
}

function submitKey() {
  const val = document.getElementById('apiKeyInput').value.trim();
  const err = document.getElementById('apiErr');
  if (!val.startsWith('sk-ant-')) {
    err.style.display = 'block';
    document.getElementById('apiKeyInput').style.borderColor = 'var(--red)';
    return;
  }
  err.style.display = 'none';
  VAULT_KEY = val;
  document.getElementById('apiModal').classList.add('hidden');
}

document.getElementById('apiKeyInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') submitKey();
});

// ══════════════════════════════════
// BOOT
// ══════════════════════════════════
const BOOT_LINES = [
  { t:'Loading secure enclave…', s:'OK', c:'ok', d:250 },
  { t:'Generating ephemeral session keys…', s:'OK', c:'ok', d:500 },
  { t:'Patching navigator.geolocation API…', s:'OK', c:'ok', d:750 },
  { t:'Blocking IP leak vectors…', s:'OK', c:'ok', d:950 },
  { t:'Disabling telemetry…', s:'OK', c:'ok', d:1150 },
  { t:'Cloud sync…', s:'BLOCKED', c:'block', d:1350 },
  { t:'Advertising trackers…', s:'BLOCKED', c:'block', d:1500 },
  { t:'AI core initialized…', s:'ONLINE', c:'ok', d:1700 },
];

(function boot() {
  document.getElementById('sessId').textContent = S.sessionId;
  const log = document.getElementById('bLog');
  BOOT_LINES.forEach(l => {
    setTimeout(() => {
      const d = document.createElement('div');
      d.className = `bl ${l.c}`;
      d.innerHTML = `<span class="bl-p">[SYS]</span><span class="bl-t">${l.t}</span><span class="bl-s">${l.s}</span>`;
      log.appendChild(d);
    }, l.d);
  });
  setTimeout(() => { document.getElementById('bProg').style.width = '100%'; }, 300);
  setTimeout(() => { document.getElementById('bEnter').classList.add('show'); }, 2000);
  setTimeout(launch, 3500);
})();

function launch() {
  const b = document.getElementById('boot');
  if (b.classList.contains('out')) return;
  b.classList.add('out');
  setTimeout(() => {
    b.style.display = 'none';
    initPrivChecks();
    sysMsg('SESSION ACTIVE · ' + S.sessionId + ' · ALL SYSTEMS NOMINAL');
    aiMsg("**VAULT secure session initialized.**\n\nAll communications are end-to-end encrypted. I'm your private AI — specialized in security, privacy, and device hardening.\n\nYour **location is currently masked** — tap the 📍 tab to configure spoofing. Use the 🛡️ tab to audit your privacy posture.\n\nWhat would you like to secure today?");
  }, 600);
}

// ══════════════════════════════════
// TABS
// ══════════════════════════════════
function switchTab(id) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  document.getElementById('panel-' + id).classList.add('active');
}

// ══════════════════════════════════
// CHAT
// ══════════════════════════════════
function ts() { return new Date().toLocaleTimeString('en-US',{hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'}); }
function fmt(t) {
  return t
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/`(.*?)`/g,`<code style="font-family:var(--mono);font-size:11px;color:var(--cyan);background:rgba(0,229,255,0.07);padding:1px 4px;">$1</code>`)
    .replace(/\n/g,'<br>');
}
function esc(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function scrollDown(){ const m=document.getElementById('msgs'); requestAnimationFrame(()=>m.scrollTop=m.scrollHeight); }

function sysMsg(t){
  const el=document.createElement('div'); el.className='sys-msg'; el.textContent=t;
  document.getElementById('msgs').appendChild(el); scrollDown();
}

function userMsg(t){
  const el=document.createElement('div'); el.className='msg user';
  el.innerHTML=`<div class="av user">YOU</div><div class="mb"><div class="bub">${esc(t)}</div><div class="msg-foot"><span class="enc">🔒</span><span>ENCRYPTED · ${ts()}</span></div></div>`;
  document.getElementById('msgs').appendChild(el); scrollDown();
}

function showThink(){
  const el=document.createElement('div'); el.className='msg ai'; el.id='think';
  el.innerHTML=`<div class="av ai" style="position:relative">AI</div><div class="mb"><div class="think-bub"><div class="td"></div><div class="td"></div><div class="td"></div></div></div>`;
  document.getElementById('msgs').appendChild(el); scrollDown();
}
function rmThink(){ const e=document.getElementById('think'); if(e) e.remove(); }

function aiMsg(t){
  rmThink();
  const el=document.createElement('div'); el.className='msg ai';
  el.innerHTML=`<div class="av ai" style="position:relative">AI</div><div class="mb"><div class="bub" style="position:relative">${fmt(t)}</div><div class="msg-foot"><span class="enc">🔒</span><span>AES-256 · LOCAL · ${ts()}</span></div></div>`;
  document.getElementById('msgs').appendChild(el); scrollDown();
}

function streamStart(){
  rmThink();
  const el=document.createElement('div'); el.className='msg ai'; el.id='streamEl';
  el.innerHTML=`<div class="av ai" style="position:relative">AI</div><div class="mb"><div class="bub" style="position:relative" id="streamBub"><span class="cursor"></span></div><div class="msg-foot"><span class="enc">🔒</span><span>STREAMING · ${ts()}</span></div></div>`;
  document.getElementById('msgs').appendChild(el); scrollDown();
  return document.getElementById('streamBub');
}
function streamEnd(){
  const el=document.getElementById('streamEl'); if(!el) return;
  el.removeAttribute('id');
  const c=el.querySelector('.cursor'); if(c) c.remove();
}

function qs(t){ document.getElementById('inp').value=t; send(); }

async function send(){
  const inp=document.getElementById('inp');
  const t=inp.value.trim();
  if(!t||S.thinking) return;
  S.thinking=true; inp.value=''; inp.style.height='auto';
  document.getElementById('sendBtn').disabled=true;
  userMsg(t);
  S.msgs.push({role:'user',content:t});
  showThink();

  const locCtx = S.locMode==='mask' ? `Location mode: SPOOFED as ${S.spoofCity?.city||'unknown'}.`
    : S.locMode==='live' ? 'Location mode: LIVE GPS active.'
    : 'Location mode: FULLY DISABLED.';

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json','x-api-key':VAULT_KEY,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system:`You are VAULT, a privacy-first AI security assistant. Context: ${locCtx} You specialize in mobile security, location privacy, data minimization, encryption, device hardening, and digital anonymity. Be precise, confident, and tactical. Use **bold** for key terms. Keep responses concise but impactful. Think like a trusted security operative.`,
        messages:S.msgs,
        stream:true
      })
    });
    if(!res.ok) throw new Error('HTTP '+res.status);
    const bub=streamStart();
    let full='',disp='';
    const reader=res.body.getReader(), dec=new TextDecoder();
    while(true){
      const{done,value}=await reader.read(); if(done) break;
      const chunk=dec.decode(value,{stream:true});
      for(const line of chunk.split('\n')){
        if(!line.startsWith('data: ')) continue;
        const d=line.slice(6).trim(); if(d==='[DONE]') continue;
        try{const j=JSON.parse(d); if(j.type==='content_block_delta'&&j.delta?.text){full+=j.delta.text;disp+=j.delta.text;bub.innerHTML=fmt(disp)+'<span class="cursor"></span>';scrollDown();}}catch{}
      }
    }
    streamEnd();
    S.msgs.push({role:'assistant',content:full});
  } catch(e) {
    rmThink();
    aiMsg(`**[CONNECTION ERROR]**\n\nCould not reach AI backend. To activate: deploy this PWA with an Anthropic API key on your server.\n\n\`${e.message}\``);
  }
  S.thinking=false;
  document.getElementById('sendBtn').disabled=false;
}

